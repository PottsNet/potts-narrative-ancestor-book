<script>
(function () {
    const searchBaseUrl = <?= json_encode($base_url, JSON_UNESCAPED_SLASHES) ?>;
    const personInput = document.getElementById('nab-person');
    const xrefInput = document.getElementById('nab-xref');
    const optionsList = document.getElementById('nab-person-options');
    const selectedText = document.getElementById('nab-selected-person');
    let timer = null;
    let suggestions = [];

    function searchUrl(term) {
        const url = new URL(searchBaseUrl, window.location.href);
        url.searchParams.set('action', 'search');
        url.searchParams.set('q', term);
        return url.toString();
    }

    function setSelected(match) {
        if (match) {
            xrefInput.value = match.xref;
            selectedText.textContent = 'Selected: ' + match.label;
        } else {
            xrefInput.value = '';
            selectedText.textContent = '';
        }
    }

    function refreshSelection() {
        const value = personInput.value;
        const exact = suggestions.find(function (item) {
            return item.label === value || item.name === value || value.endsWith('[' + item.xref + ']');
        });

        setSelected(exact || null);
    }

    personInput.addEventListener('input', function () {
        const term = personInput.value.trim();
        setSelected(null);
        window.clearTimeout(timer);

        if (term.length < 2) {
            suggestions = [];
            optionsList.innerHTML = '';
            return;
        }

        timer = window.setTimeout(function () {
            fetch(searchUrl(term), {headers: {'Accept': 'application/json'}})
                .then(function (response) { return response.ok ? response.json() : []; })
                .then(function (items) {
                    suggestions = Array.isArray(items) ? items : [];
                    optionsList.innerHTML = '';

                    suggestions.forEach(function (item) {
                        const option = document.createElement('option');
                        option.value = item.label;
                        option.dataset.xref = item.xref;
                        optionsList.appendChild(option);
                    });

                    refreshSelection();
                })
                .catch(function () {
                    suggestions = [];
                    optionsList.innerHTML = '';
                });
        }, 250);
    });

    personInput.addEventListener('change', refreshSelection);

    document.getElementById('nab-form').addEventListener('submit', function () {
        refreshSelection();
    });
}());
</script>

