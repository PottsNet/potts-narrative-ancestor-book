/** @var string $error */
/** @var array<string,mixed>|null $book */

if (!function_exists('nab_checked')) {
    function nab_checked(array $options, string $key): string
    {
        return !empty($options[$key]) ? ' checked' : '';
    }
}

$base_url = route($module_class, ['tree' => $tree->name()]);
$base_path = $base_url;
$base_query = [];
$base_query_text = parse_url($base_url, PHP_URL_QUERY);

if (is_string($base_query_text) && $base_query_text !== '') {
    parse_str($base_query_text, $base_query);
    $base_path = strtok($base_url, '?') ?: $base_url;
}

$download_url = '';

if (is_array($book)) {
    $download_query = http_build_query(array_merge($base_query, (array) $book['query'], ['download' => 'html']));
    $download_url = $base_path . '?' . $download_query;
}
